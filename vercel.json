{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "regions": ["hkg1"],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "focword.cn" }],
      "destination": "https://blog.focword.cn/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/posts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=7200, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(categories|tags)(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=7200, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/feed.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=7200, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
